# Vortex environment template. Copy to .env and fill in. Never commit real secrets.

# ---- Control-plane API (apps/api) ----
VORTEX_ENV=development
VORTEX_HTTP_ADDR=:8080
VORTEX_CORS_ORIGINS=http://localhost:3000

# Postgres (control-plane data). Used from Milestone 2 onward.
VORTEX_DATABASE_URL=postgres://viro:viro@localhost:5432/viro?sslmode=disable

# Auth / JWT
VORTEX_JWT_SECRET=dev-insecure-secret-change-me
VORTEX_JWT_ACCESS_TTL_MIN=15
VORTEX_JWT_REFRESH_TTL_HOURS=720

# ---- Coolify (orchestration backend) ----
# Base URL of your Coolify instance and an API token (read+write+deploy abilities).
VORTEX_COOLIFY_BASE_URL=http://localhost:8000
VORTEX_COOLIFY_TOKEN=

# ---- Billing (Stripe, test-mode) ----
VORTEX_BILLING_ENABLED=false
VORTEX_STRIPE_SECRET_KEY=sk_test_xxx
VORTEX_STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Web UI (apps/web) ----
NEXT_PUBLIC_VORTEX_API_URL=http://localhost:8080
