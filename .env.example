# Viro environment template. Copy to .env and fill in. Never commit real secrets.

# ---- Control-plane API (apps/api) ----
VIRO_ENV=development
VIRO_HTTP_ADDR=:8080
VIRO_CORS_ORIGINS=http://localhost:3000

# Postgres (control-plane data). Used from Milestone 2 onward.
VIRO_DATABASE_URL=postgres://viro:viro@localhost:5432/viro?sslmode=disable

# Auth / JWT
VIRO_JWT_SECRET=dev-insecure-secret-change-me
VIRO_JWT_ACCESS_TTL_MIN=15
VIRO_JWT_REFRESH_TTL_HOURS=720

# ---- Coolify (orchestration backend) ----
# Base URL of your Coolify instance and an API token (read+write+deploy abilities).
VIRO_COOLIFY_BASE_URL=http://localhost:8000
VIRO_COOLIFY_TOKEN=

# ---- Billing (Stripe, test-mode) ----
VIRO_BILLING_ENABLED=false
VIRO_STRIPE_SECRET_KEY=sk_test_xxx
VIRO_STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Web UI (apps/web) ----
NEXT_PUBLIC_VIRO_API_URL=http://localhost:8080
